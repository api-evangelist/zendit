{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PurchaseList",
  "description": "Paginated purchase list.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/zendit/refs/heads/main/json-schema/zendit-api-purchase-list-schema.json",
  "type": "object",
  "properties": {
    "list": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Purchase"
      },
      "example": [
        {}
      ]
    },
    "offset": {
      "type": "integer",
      "example": 0
    },
    "limit": {
      "type": "integer",
      "example": 100
    },
    "total": {
      "type": "integer",
      "example": 50
    }
  }
}