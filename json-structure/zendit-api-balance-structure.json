{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/zendit/refs/heads/main/json-structure/zendit-api-balance-structure.json",
  "name": "Balance",
  "description": "Wallet balance and currency information.",
  "type": "object",
  "properties": {
    "amount": {
      "type": "double",
      "description": "Available balance amount.",
      "example": 1234.56
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code.",
      "example": "USD"
    },
    "accountId": {
      "type": "string",
      "description": "Account identifier.",
      "example": "acc-12345"
    }
  }
}